# ─── Amadeus API ───────────────────────────────────────────
# Cadastre-se grátis em https://developers.amadeus.com
# Depois de criar uma conta, vá em "My Self-Service Workspace" > "Create new app"
# Copie o API Key (client_id) e API Secret (client_secret) abaixo:

AMADEUS_CLIENT_ID=coloque_seu_client_id_aqui
AMADEUS_CLIENT_SECRET=coloque_seu_client_secret_aqui

# Ambiente: 'test' (grátis, dados de teste) ou 'production' (dados reais)
AMADEUS_ENV=test

# Porta do servidor (opcional, padrão: 3000)
# PORT=3000
